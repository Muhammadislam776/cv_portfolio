<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %>
  </title>
  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <!-- Main CSS -->
  <link rel="stylesheet" href="/css/styles.css">
  <!-- AOS Animation Library -->
  <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
</head>

<body class="custom-cursor">
  <!-- Custom Cursor Elements -->
  <div class="custom-cursor-dot"></div>
  <div class="custom-cursor-ring"></div>
  <div class="scroll-progress"></div>

  <!-- TOP N AVIGATION BAR -->
  <nav class="navbar navbar-expand-lg navbar-dark fixed-top width-100%"
    style="background:#07181c; border-bottom: 2px solid var(--main-color);">
    <div class="container d-flex align-items-center justify-content-between">

      <div class="d-flex align-items-center gap-2 order-0">
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
          aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation"
          style="border-color: var(--main-color);">
          <span class="navbar-toggler-icon"></span>
        </button>
        <a class="navbar-brand m-0" href="/" style="font-weight: 700; font-size: 24px;">
          Muhammad <span style="color: var(--main-color);">Islam</span>
        </a>
      </div>

      <!-- Navigation links (Hidden on mobile inside hamburger) -->
      <div class="collapse navbar-collapse order-3 order-lg-1" id="navbarNav">
        <ul class="navbar-nav mx-auto mb-2 mb-lg-0 text-center">
          <li class="nav-item">
            <a class="nav-link <%= page==='home' ? 'active' : '' %>" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= page==='about' ? 'active' : '' %>" href="/about">About</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= page==='experience' ? 'active' : '' %>" href="/experience">Experience</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= page==='projects' ? 'active' : '' %>" href="/projects">Projects</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= page==='contact' ? 'active' : '' %>" href="/contact">Contact</a>
          </li>
        </ul>
      </div>

      <!-- Socials and Settings at the right, visible on mobile -->
      <div class="d-flex align-items-center gap-4 order-1 order-lg-2">

        <!-- Socials -->
        <div class="header-social d-flex gap-4">
          <a href="https://github.com/Muhammadislam776" target="_blank" style="color:rgb(125, 117, 117);"><i
              class="bi bi-github"></i></a>
          <a href="https://linkedin.com/in/muhammad-islam-4878a9342" target="_blank"
            style="color: rgb(125, 117, 117);"><i class="bi bi-linkedin"></i></a>
          <a href="https://wa.me/923196590756" target="_blank" style="color: rgb(125, 117, 117);"><i
              class="bi bi-whatsapp"></i></a>
        </div>

        <!-- Settings Panel Toggle -->
        <div class="settings-container position-relative">
          <button id="theme-settings-toggle" class="btn btn-link p-0"
            style="color: var(--main-color); font-size: 20px;">
            <i class="bi bi-gear-fill"></i>
          </button>
          <!-- Panel -->
          <div id="theme-settings-panel" class="settings-panel"
            style="display: none; position: absolute; right: 0; top: 100%; margin-top: 15px; background: #111; border: 1px solid var(--main-color); padding: 15px; border-radius: 8px; box-shadow: 0px 5px 15px rgba(0,0,0,0.5); width: 200px; z-index: 1050;">
            <h6 style="color: white; margin-bottom: 15px; font-weight: bold;">Settings</h6>

            <div class="mb-3">
              <label style="color: white; font-size: 13px; display: block; margin-bottom: 5px;">Theme Mode:</label>
              <select id="theme-mode-picker" class="form-select form-select-sm"
                style="background-color: #222; color: white; border-color: #444;">
                <option value="dark">Dark Mode</option>
                <option value="light">Light Mode</option>
              </select>
            </div>

            <div class="mb-3">
              <label style="color: white; font-size: 13px; display: block; margin-bottom: 5px;">Theme Color:</label>
              <input type="color" id="theme-color-picker" value="#00e6d0"
                style="width: 100%; height: 35px; border: none; padding: 0; background: none; cursor: pointer;">
            </div>

            <div class="mb-3">
              <label style="color: white; font-size: 13px; display: block; margin-bottom: 5px;">Cursor Style:</label>
              <select id="cursor-style-picker" class="form-select form-select-sm"
                style="background-color: #222; color: white; border-color: #444;">
                <option value="advanced">Advanced (Dot & Ring)</option>
                <option value="simple">Simple (Default)</option>
              </select>
            </div>

            <div class="d-flex justify-content-between mt-4">
              <button id="theme-settings-close" class="btn btn-sm btn-outline-light"
                style="font-size: 12px;">Close</button>
              <button id="theme-settings-apply" class="btn btn-sm"
                style="background: var(--main-color); color: #000; font-size: 12px; font-weight: bold;">Apply</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </nav>